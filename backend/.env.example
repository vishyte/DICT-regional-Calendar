# Database Configuration
# For Render: Leave empty - Render will auto-provision and set DATABASE_URL
# For local PostgreSQL: postgres://username:password@localhost:5432/yourdb
DATABASE_URL=

# JWT Configuration
# Generate a secure random string for production (e.g., use openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server Configuration
PORT=3001

# Frontend URL (update for production)
FRONTEND_URL=http://localhost:5173

# Superadmin Credentials (change these for production)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=admin123

# Node Environment
NODE_ENV=production
